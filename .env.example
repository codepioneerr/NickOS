# ═══════════════════════════════════════════════════════════
#  NickOS — .env.example
#  Copy to .env and fill in every value before running.
#  Never commit .env to git.
# ═══════════════════════════════════════════════════════════

# ── Telegram ──────────────────────────────────────────────
# Get from @BotFather → /newbot
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your personal Telegram user ID (NOT username)
# Find it: message @userinfobot or @getidsbot
TELEGRAM_ALLOWED_USER_ID=your_numeric_user_id

# ── Anthropic (Claude API) ────────────────────────────────
# https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# Models (defaults — change if needed)
ANTHROPIC_HAIKU_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_SONNET_MODEL=claude-sonnet-4-6

# ── Gmail shared ──────────────────────────────────────────
# One credentials.json from Google Cloud Console covers all 4 accounts.
# https://console.cloud.google.com → APIs & Services → Credentials
# Download as credentials.json (Desktop App type)
GMAIL_CREDENTIALS_PATH=./gmail/credentials.json

# ── Gmail Account 1 (required) ────────────────────────────
GMAIL_ACCOUNT_1_NAME=Main
GMAIL_ACCOUNT_1_EMAIL=you@gmail.com
GMAIL_ACCOUNT_1_TOKEN=./gmail/tokens/account1_token.json

# ── Gmail Account 2 (optional) ────────────────────────────
GMAIL_ACCOUNT_2_NAME=School
GMAIL_ACCOUNT_2_EMAIL=
GMAIL_ACCOUNT_2_TOKEN=./gmail/tokens/account2_token.json

# ── Gmail Account 3 (optional) ────────────────────────────
GMAIL_ACCOUNT_3_NAME=Trading
GMAIL_ACCOUNT_3_EMAIL=
GMAIL_ACCOUNT_3_TOKEN=./gmail/tokens/account3_token.json

# ── Gmail Account 4 (optional) ────────────────────────────
GMAIL_ACCOUNT_4_NAME=Business
GMAIL_ACCOUNT_4_EMAIL=
GMAIL_ACCOUNT_4_TOKEN=./gmail/tokens/account4_token.json

# Authorize each account:
#   python scripts/setup_gmail_oauth.py --account 1
#   python scripts/setup_gmail_oauth.py --account 2  (etc.)
# Check status:
#   python scripts/setup_gmail_oauth.py --list

# ── Google Calendar ───────────────────────────────────────
# Same OAuth credentials as Gmail (same credentials.json works)
GOOGLE_CALENDAR_ID=primary

# ── App settings ──────────────────────────────────────────
TIMEZONE=America/New_York
NICKOS_ROOT=/Users/nick/Documents/Agentic Workflows/NickOS

# ── Database ──────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/nickos.db

# ── FastAPI ───────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change_me_to_a_random_string

# ── Railway (for deployment) ──────────────────────────────
# Set these in Railway dashboard → Variables, not here
# RAILWAY_TOKEN=
# RAILWAY_PROJECT_ID=
